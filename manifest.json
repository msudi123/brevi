{
  "manifest_version": 3,
  "name": "Brevi",
  "version": "1.0.0",
  "description": "Finds free coverage of paywalled articles and summarizes it clearly.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*",
    "https://brevi-psi.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Brevi",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "sidebar.html",
        "sidebar.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
